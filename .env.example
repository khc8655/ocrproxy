# 环境变量模板 — 复制为 .env 后填入真实值
# ⚠️ 此文件不要提交到 git

# Fernet 加密密钥 — 保护数据库中存储的上游 API Key
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_KEY=

# 代理 API 密钥 — agent 调用 /v1/* 时必须带 Authorization: Bearer <此值>
# 生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
PROXY_API_KEY=

# 管理面板登录密码
ADMIN_PASSWORD=

# SQLite 路径 (Docker 内)
DB_PATH=/app/data/proxy.db

# 每个 Key 的最大并发数
MAX_CONCURRENCY_PER_KEY=5

# 熔断阈值 (连续失败次数)
CIRCUIT_BREAK_THRESHOLD=3

# 熔断冷却时长 (秒)
CIRCUIT_COOLDOWN_SEC=300

# 429 冷却时长 (秒)
COOLDOWN_429_SEC=60

# 403 冷却时长 (秒)
COOLDOWN_403_SEC=600

# 上游请求超时 (秒)
UPSTREAM_TIMEOUT_SEC=120
